{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with specific roles and permissions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "manager", "accountant"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Center": {
      "title": "Center",
      "description": "A commercial center managed by the platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Building": {
      "title": "Building",
      "description": "A building within a commercial center.",
      "type": "object",
      "properties": {
        "centerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["centerId", "name"]
    },
    "Unit": {
      "title": "Unit",
      "description": "A specific shop or office within a building.",
      "type": "object",
      "properties": {
        "buildingId": { "type": "string" },
        "centerId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["shop", "office"] },
        "status": { "type": "string", "enum": ["occupied", "free", "maintenance"] },
        "floor": { "type": "string" }
      },
      "required": ["buildingId", "centerId", "name", "type", "status"]
    },
    "Tenant": {
      "title": "Tenant",
      "description": "A person or company renting a unit.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "manager": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "activityType": { "type": "string" }
      },
      "required": ["name"]
    },
    "Contract": {
      "title": "Contract",
      "description": "A lease agreement between a tenant and a unit.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "unitId": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "rentAmount": { "type": "number" },
        "chargesIncluded": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "expired", "terminated"] }
      },
      "required": ["tenantId", "unitId", "startDate", "rentAmount", "status"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A monthly bill for a tenant.",
      "type": "object",
      "properties": {
        "contractId": { "type": "string" },
        "tenantId": { "type": "string" },
        "unitId": { "type": "string" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "amountRent": { "type": "number" },
        "amountWater": { "type": "number" },
        "amountElectricity": { "type": "number" },
        "totalAmount": { "type": "number" },
        "amountPaid": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "unpaid", "partial"] },
        "dueDate": { "type": "string", "format": "date" }
      },
      "required": ["contractId", "tenantId", "month", "year", "totalAmount", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment record for an invoice.",
      "type": "object",
      "properties": {
        "invoiceId": { "type": "string" },
        "tenantId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "method": { "type": "string", "enum": ["cash", "mobile_money", "bank"] },
        "reference": { "type": "string" }
      },
      "required": ["invoiceId", "tenantId", "amount", "date", "method"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles and roles" },
    "/centers/{centerId}": { "schema": "Center", "description": "Commercial centers" },
    "/buildings/{buildingId}": { "schema": "Building", "description": "Buildings within centers" },
    "/units/{unitId}": { "schema": "Unit", "description": "Rental units" },
    "/tenants/{tenantId}": { "schema": "Tenant", "description": "Tenant information" },
    "/contracts/{contractId}": { "schema": "Contract", "description": "Lease contracts" },
    "/invoices/{invoiceId}": { "schema": "Invoice", "description": "Monthly invoices" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payment records" }
  }
}
