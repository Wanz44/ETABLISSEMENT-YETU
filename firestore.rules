rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, email, role (admin, manager, accountant), createdAt
    //
    // Collection: centers
    // Fields: name, location, description, createdAt
    //
    // Collection: buildings
    // Fields: centerId, name, description
    //
    // Collection: units
    // Fields: buildingId, centerId, name, type (shop, office), status (occupied, free, maintenance), floor
    //
    // Collection: tenants
    // Fields: name, company, manager, phone, email, activityType
    //
    // Collection: contracts
    // Fields: tenantId, unitId, startDate, endDate, rentAmount, chargesIncluded, status (active, expired, terminated)
    //
    // Collection: invoices
    // Fields: contractId, tenantId, unitId, month, year, amountRent, amountWater, amountElectricity, totalAmount, amountPaid, status (paid, unpaid, partial), dueDate
    //
    // Collection: payments
    // Fields: invoiceId, tenantId, amount, date, method (cash, mobile_money, bank), reference
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return true; // Login system removed as requested
    }

    function isAdmin() {
      return true; // Default to admin for all actions
    }

    function isManager() {
      return true;
    }

    function isAccountant() {
      return true;
    }

    function isOwner(userId) {
      return true;
    }

    function isValidEmail(email) {
      return email is string;
    }

    function isValidUser(data) {
      return true;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if true;
    }

    match /centers/{centerId} {
      allow read, write: if true;
    }

    match /buildings/{buildingId} {
      allow read, write: if true;
    }

    match /units/{unitId} {
      allow read, write: if true;
    }

    match /tenants/{tenantId} {
      allow read, write: if true;
    }

    match /contracts/{contractId} {
      allow read, write: if true;
    }

    match /invoices/{invoiceId} {
      allow read, write: if true;
    }

    match /payments/{paymentId} {
      allow read, write: if true;
    }

    match /expenses/{expenseId} {
      allow read, write: if true;
    }
  }
}
